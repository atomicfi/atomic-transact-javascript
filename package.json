{
  "version": "0.0.0-development",
  "name": "@atomicfi/transact-javascript",
  "description": "Atomic Transact Javascript SDK.",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "format:check": "prettier --check index.js",
    "format": "prettier --write index.js",
    "audit:fix": "npm audit fix --min-release-age=0",
    "prepublishOnly": "node scripts/update-version.js && npx tsc"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.16.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11.13.0",
      "onFail": "error"
    }
  },
  "keywords": [
    "Atomic",
    "Transact",
    "Javascript",
    "SDK"
  ],
  "author": "sean@atomicfi.com",
  "license": "ISC",
  "devDependencies": {
    "lodash": "^4.17.23",
    "prettier": "^2.4.1",
    "typescript": "^4.6.4",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atomicfi/atomic-transact-javascript.git"
  },
  "bugs": {
    "url": "https://github.com/atomicfi/atomic-transact-javascript/issues"
  },
  "homepage": "https://github.com/atomicfi/atomic-transact-javascript#readme"
}
